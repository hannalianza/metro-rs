    <script>
    $(document).ready(function() {
        var currentZipcode = $('#czipcode').text().trim();
        if (currentZipcode) {
            $.ajax({
                type: 'GET',
                url: '/api/xt.get.city.zipcode.php',
                data: {
                    'zipcode': currentZipcode
                },
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                cache: false,
                success: function(response) {
                    var returnVal = response.returnVal;
                    console.log(returnVal)
                    //var errorMsg = response.ErrorMessage;
                    if (returnVal == 200) {
                        $('#city').text(response.data.city);
                        $('#state').text(response.data.state);
                        return false;
                    } else {
                        alert(response.message);
                        // window.location.reload();
                    }
                },
                error: function(jqXHR, error, errorThrown) {
                    console.error(error)
                    alert(formatErrorMessage(jqXHR, error));
                    return false;
                }
            });
        }

        // Show modal when member link is clicked
        $('#czipcode').on('click', function() {
            $('#zipcodeModal').modal('show');
        });
        $('#czipcode2').on('click', function() {
            $('#zipcodeModal').modal('show');
        });

        // Save new zip code
        $('#saveZipcode').on('click', function() {
            var newZipcode = $('#newZipcode').val();

            var zipRegex = /^\d{5}(?:-\d{4})?$/;

            if (newZipcode) {
                $.ajax({
                    type: 'GET',
                    url: '/api/xt.get.city.zipcode.php',
                    data: {
                        'zipcode': newZipcode
                    },
                    dataType: "json",
                    contentType: "application/json; charset=utf-8",
                    cache: false,
                    success: function(response) {
                        var returnVal = response.returnVal;
                        if (returnVal == 200) {
                            $('#city').text(response.data.city);
                            $('#state').text(response.data.state);

                            if (zipRegex.test(newZipcode)) {
                                $('#czipcode').text(newZipcode);

                                $.ajax({
                                    type: "POST",
                                    url: "/update_session.php", // URL of your PHP script
                                    data: {
                                        zipcode: newZipcode
                                    }, // Data to be sent
                                    success: function(response) {
                                        window.location.reload();
                                    },
                                    error: function(xhr, status, error) {
                                        console.error(xhr
                                            .responseText
                                        ); // Optional: Log the error
                                        // Handle error (if needed)
                                    }
                                });

                                $('#zipcodeModal').modal('hide');
                            } else {
                                alert("Invalid ZIP code. Please enter a valid ZIP code.");
                            }
                            return false;
                        } else {
                            alert(response.error);
                            // window.location.reload();
                        }
                    },
                    error: function(jqXHR, error, errorThrown) {
                        console.error(error)
                        alert(formatErrorMessage(jqXHR, error));
                        return false;
                    }
                });
            }

        });
    });
    </script>

    <!-- Modal -->

    <div aria-hidden="true" aria-labelledby="zipcodeModalLabel" class="modal fade" id="zipcodeModal" role="dialog"
        tabindex="-1" data-keyboard="false" data-backdrop="static">
        <div class="modal-dialog" style="float:none;margin:auto;">
            <div class="modal-content">
